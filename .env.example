# Kripto Coin Analiz Uygulaması — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve API key'lerinizi girin.

# CryptoPanic API Key (Ücretsiz)
# https://cryptopanic.com/developers/api/ adresinden alın
CRYPTOPANIC_API_KEY=

# Reddit API (Opsiyonel)
# https://www.reddit.com/prefs/apps adresinden alın
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Telegram Bildirim Ayarları (Opsiyonel)
# Bot Token almak için Telegram'da @BotFather kullanın.
TELEGRAM_TOKEN=

# İşlem (Al/Sat/Kâr) bildirimlerinin gideceği Chat/Kanal ID'si
TELEGRAM_CHAT_ID=

# Sadece verilerin (JSON Cloud Sync) gideceği ayrı Chat/Kanal ID'si (Opsiyonel)
# Eğer boş bırakılırsa veriler TELEGRAM_CHAT_ID'ye gönderilir.
TELEGRAM_DATA_CHAT_ID=
